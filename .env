-- 3. Add foreign key for customer (if not yet set)
alter table appointments
add constraint fk_customer
foreign key (customer_id)
references users(id)
on delete cascade;

-- 4. Add foreign key for service (if not yet set)
alter table appointments
add constraint fk_service
foreign key (service_id)
references services(id)
on delete cascade;

-- 5. Add status constraint
alter table appointments
add constraint check_status
check (
  status in (
    'pending',
    'confirmed',
    'in_progress',
    'ready_for_pickup',
    'completed',
    'cancelled'
  )
);

-- 6. Set default status
alter table appointments
alter column status set default 'pending';

